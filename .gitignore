/target/
**/target/

# Cargo
/Cargo.lock

# Build artifacts
*.rs.bk
*.pdb

# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
